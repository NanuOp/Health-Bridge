<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_dark"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_greeting"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Good morning, Shiv"
                    android:textColor="@color/text_primary"
                    android:textSize="22sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="April 27 · Monday"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/tv_battery"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:text="BAT 85%"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </RelativeLayout>

        <!-- Recovery Ring Section -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="24dp">

            <View
                android:id="@+id/view_ring_pulse"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center"
                android:background="@drawable/pulse_glow" />

            <com.nanu.healthbridge.ui.views.CircularProgressView
                android:id="@+id/recovery_ring"
                android:layout_width="240dp"
                android:layout_height="240dp"
                android:layout_gravity="center" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tv_recovery_score"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textColor="@color/text_primary"
                    android:textSize="64sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tv_recovery_zone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CALCULATING"
                    android:textColor="@color/accent_green"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </FrameLayout>

        <!-- Metric Row -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <!-- HR Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/BiopunkCard"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginEnd="12dp">
                    
                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_gradient"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="HR"
                            android:textColor="#FF6B8A"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_hr_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="32sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- SpO2 Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/BiopunkCard"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginEnd="12dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_gradient"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="SpO2"
                            android:textColor="@color/accent_blue"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_spo2_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="--"
                            android:textColor="@color/text_primary"
                            android:textSize="32sp"
                            android:textStyle="bold" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Sleep Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/BiopunkCard"
                    android:layout_width="140dp"
                    android:layout_height="140dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_gradient"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Sleep"
                            android:textColor="@color/accent_purple"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_sleep_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="--h"
                            android:textColor="@color/text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_sleep_bedtime"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tv_sleep_value"
                            android:layout_centerHorizontal="true"
                            android:text="--:--"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />

                        <TextView
                            android:id="@+id/tv_sleep_warning"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_centerHorizontal="true"
                            android:text="⚠️ Late sleep"
                            android:textColor="#FFA500"
                            android:textSize="9sp"
                            android:visibility="gone" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Steps Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/BiopunkCard"
                    android:layout_width="140dp"
                    android:layout_height="140dp"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_gradient"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Steps"
                            android:textColor="@color/accent_green"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_steps_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="0"
                            android:textColor="@color/text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_steps_goal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_centerHorizontal="true"
                            android:text="Goal: 10k"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

                <!-- Strain Card -->
                <com.google.android.material.card.MaterialCardView
                    style="@style/BiopunkCard"
                    android:layout_width="140dp"
                    android:layout_height="140dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@drawable/card_gradient"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Strain"
                            android:textColor="@color/accent_purple"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_strain_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_centerInParent="true"
                            android:text="0.0"
                            android:textColor="@color/text_primary"
                            android:textSize="24sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_strain_level_dash"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentBottom="true"
                            android:layout_centerHorizontal="true"
                            android:text="RESTORATIVE"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </RelativeLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </HorizontalScrollView>

        <!-- Quick Actions -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_sync_all"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Sync Historical Data"
                android:textColor="@color/accent_blue"
                app:cornerRadius="16dp"
                app:icon="@android:drawable/stat_notify_sync"
                app:iconTint="@color/accent_blue"
                app:strokeColor="@color/accent_blue" />
        </LinearLayout>

        <!-- Readiness Banner -->
        <com.google.android.material.card.MaterialCardView
            style="@style/BiopunkCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_gradient"
                android:orientation="horizontal"
                android:padding="16dp">

                <View
                    android:id="@+id/banner_accent_border"
                    android:layout_width="4dp"
                    android:layout_height="match_parent"
                    android:background="@color/accent_green" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_readiness_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Readiness"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_readiness_insight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Calculating your recovery state..."
                        android:textColor="@color/text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Extra spacing for bottom nav -->
        <View
            android:layout_width="match_parent"
            android:layout_height="80dp" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
